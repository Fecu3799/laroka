VITE_API_URL=http://localhost:8080
VITE_APP_URL=http://localhost:5173
# Habilita logs [MP-DEBUG] de MercadoPago en consola del navegador
VITE_DEV_MP_DEBUG_LOGS=true

# Clave pública VAPID para Web Push. Debe ser la pareja pública de la clave
# privada configurada en el backend (VAPID_PRIVATE_KEY). El prefijo VITE_ es
# obligatorio para que Vite la exponga vía import.meta.env en el cliente.
VITE_VAPID_PUBLIC_KEY=replace-with-generated-public-key