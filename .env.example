# Master switch — setear false (u omitir) antes de lanzar a producción.
# Cuando es true, habilita todas las flags de desarrollo en bloque.
APP_DEV_MODE=true

# Overrides individuales (opcional — si no se setean, usan el valor de APP_DEV_MODE)
# Permite pedidos fuera del horario de atención de la sucursal
APP_DEV_BYPASS_BRANCH_HOURS=true
# Omite validación HMAC de webhooks de MercadoPago (nunca true en producción)
APP_DEV_SKIP_WEBHOOK_VALIDATION=false
# Expone Swagger UI y OpenAPI docs en /swagger-ui.html
APP_DEV_SWAGGER_ENABLED=true
# Nivel de logging para el módulo de pedidos (INFO en producción)
APP_DEV_LOG_LEVEL=DEBUG

# Rate limiting (ventana de 60 segundos por IP)
# GET /branches/{id}/menu — requests por minuto
RATE_LIMIT_MENU_MAX_REQUESTS=60
# POST /orders — requests por minuto
RATE_LIMIT_ORDERS_MAX_REQUESTS=10
# POST /auth/login — intentos de login por minuto
RATE_LIMIT_LOGIN_MAX_REQUESTS=10
# Duración de la ventana de login en segundos
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60

DB_URL=
DB_USER=
DB_PASS=

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

ORDER_EXPIRATION_MINUTES=30

# Tiempo de vida del caché de menú por sucursal (en segundos).
# Cada apertura del modal de nueva orden consume GET /branches/{id}/menu — con caché,
# solo la primera llamada va a la DB; las siguientes responden en memoria hasta que el
# TTL expire o un cambio de disponibilidad invalide la entrada correspondiente.
CACHE_MENU_TTL_SECONDS=600

R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
# Base de la URL pública del bucket R2 (sin barra final), ej:
# https://pub-xxxx.r2.dev o un dominio custom. Distinta de R2_ENDPOINT (que es
# el endpoint S3 de escritura). El endpoint de upload retorna
# {R2_PUBLIC_URL}/{tenantId}/{uuid}.{ext}.
R2_PUBLIC_URL=
# Tamaño máximo (en MB) de imagen aceptado por POST /backoffice/media/upload.
MAX_UPLOAD_SIZE_MB=5

JWT_SECRET=
# Tiempo de vida del access token JWT (en ms). Default: 30 minutos.
# Reducido desde 8 horas para acotar la ventana de exposición ante tokens capturados.
# El refresh token compensa la sesión larga.
JWT_EXPIRATION=1800000
# Tiempo de vida del refresh token (en días). Default: 7 días.
# Cada uso rota el token (el anterior se revoca inmediatamente).
REFRESH_TOKEN_EXPIRATION_DAYS=7

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Web Push (VAPID) — claves para notificar a clientes anónimos sobre cambios
# de estado de sus pedidos. Generarlas con:
#   npx web-push generate-vapid-keys --json
# La pública también debe configurarse en el frontend cliente. NUNCA commitear
# las claves reales: van solo en el .env local / variables de entorno del deploy.
VAPID_PUBLIC_KEY=replace-with-generated-public-key
VAPID_PRIVATE_KEY=replace-with-generated-private-key